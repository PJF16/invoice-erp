generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
}

enum TaxTreatment {
  STANDARD
  REVERSE_CHARGE
  INTRA_EU_SUPPLY
  EXPORT
}

enum InvoiceStatus {
  DRAFT
  OPEN
  SENT
  PAID
  CANCELED
}

enum RecurringInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum MovementType {
  IN
  OUT
  ADJUST
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         Role       @default(MEMBER)
  createdAt    DateTime   @default(now())
  movements    Movement[]
}

model Warehouse {
  id           String        @id @default(cuid())
  name         String        @unique
  location     String?
  createdAt    DateTime      @default(now())
  stocks       Stock[]
  movements    Movement[]
  invoiceLines InvoiceLine[]
}

model Item {
  id           String        @id @default(cuid())
  name         String
  sku          String?       @unique
  barcode      String?       @unique
  description  String?
  createdAt    DateTime      @default(now())
  stocks       Stock[]
  movements    Movement[]
  invoiceLines InvoiceLine[]
}

model Stock {
  id          String    @id @default(cuid())
  item        Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId      String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  warehouseId String
  quantity    Int       @default(0)

  @@unique([itemId, warehouseId])
}

model CompanySettings {
  id              String @id @default("singleton")
  name            String @default("")
  street          String @default("")
  zip             String @default("")
  city            String @default("")
  country         String @default("Österreich")
  uid             String @default("")
  iban            String @default("")
  bic             String @default("")
  bankName        String @default("")
  email           String @default("")
  phone           String @default("")
  invoicePrefix   String @default("")
  paymentDays     Int    @default(14)
  emailSubject    String @default("Rechnung {nummer}")
  emailBody       String @default("Sehr geehrte Damen und Herren,\n\nanbei erhalten Sie die Rechnung {nummer}.\n\nMit freundlichen Grüßen")
  lastInvoiceYear Int    @default(0)
  lastInvoiceSeq  Int    @default(0)
}

model Customer {
  id                  String             @id @default(cuid())
  name                String
  contactPerson       String?
  email               String?
  street              String             @default("")
  zip                 String             @default("")
  city                String             @default("")
  country             String             @default("Österreich")
  uid                 String?
  defaultTaxTreatment TaxTreatment       @default(STANDARD)
  notes               String?
  createdAt           DateTime           @default(now())
  invoices            Invoice[]
  recurringInvoices   RecurringInvoice[]
}

model SoftwareItem {
  id             String                 @id @default(cuid())
  name           String
  description    String?
  unitPrice      Decimal                @db.Decimal(10, 2)
  unit           String                 @default("Monat")
  active         Boolean                @default(true)
  createdAt      DateTime               @default(now())
  invoiceLines   InvoiceLine[]
  recurringLines RecurringInvoiceLine[]
}

model Invoice {
  id                 String            @id @default(cuid())
  number             String?           @unique
  status             InvoiceStatus     @default(DRAFT)
  customer           Customer          @relation(fields: [customerId], references: [id])
  customerId         String
  customerName       String            @default("")
  customerAddress    String            @default("")
  customerUid        String?
  issueDate          DateTime
  dueDate            DateTime
  servicePeriodStart DateTime?
  servicePeriodEnd   DateTime?
  taxTreatment       TaxTreatment      @default(STANDARD)
  notes              String?
  netTotal           Decimal           @default(0) @db.Decimal(12, 2)
  taxTotal           Decimal           @default(0) @db.Decimal(12, 2)
  grossTotal         Decimal           @default(0) @db.Decimal(12, 2)
  recurringInvoice   RecurringInvoice? @relation(fields: [recurringInvoiceId], references: [id])
  recurringInvoiceId String?
  sentAt             DateTime?
  paidAt             DateTime?
  createdAt          DateTime          @default(now())
  lines              InvoiceLine[]

  @@index([status, issueDate])
}

model InvoiceLine {
  id             String        @id @default(cuid())
  invoice        Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId      String
  position       Int
  description    String
  quantity       Decimal       @db.Decimal(10, 2)
  unit           String        @default("Stk")
  unitPrice      Decimal       @db.Decimal(10, 2)
  taxRate        Int           @default(20)
  lineNet        Decimal       @db.Decimal(12, 2)
  softwareItem   SoftwareItem? @relation(fields: [softwareItemId], references: [id], onDelete: SetNull)
  softwareItemId String?
  item           Item?         @relation(fields: [itemId], references: [id], onDelete: SetNull)
  itemId         String?
  warehouse      Warehouse?    @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  warehouseId    String?
}

model RecurringInvoice {
  id           String                 @id @default(cuid())
  name         String
  customer     Customer               @relation(fields: [customerId], references: [id])
  customerId   String
  interval     RecurringInterval      @default(MONTHLY)
  nextRun      DateTime
  active       Boolean                @default(true)
  autoSend     Boolean                @default(true)
  taxTreatment TaxTreatment           @default(STANDARD)
  notes        String?
  createdAt    DateTime               @default(now())
  lines        RecurringInvoiceLine[]
  invoices     Invoice[]
}

model RecurringInvoiceLine {
  id                 String           @id @default(cuid())
  recurringInvoice   RecurringInvoice @relation(fields: [recurringInvoiceId], references: [id], onDelete: Cascade)
  recurringInvoiceId String
  position           Int
  // Wenn softwareItemId gesetzt: Bezeichnung + Preis werden bei der Erzeugung
  // vom Softwareartikel gelesen (Preisänderungen wirken auf künftige Rechnungen).
  softwareItem       SoftwareItem?    @relation(fields: [softwareItemId], references: [id], onDelete: SetNull)
  softwareItemId     String?
  description        String?
  unitPrice          Decimal?         @db.Decimal(10, 2)
  quantity           Decimal          @db.Decimal(10, 2)
  unit               String           @default("Stk")
  taxRate            Int              @default(20)
}

model Movement {
  id          String       @id @default(cuid())
  type        MovementType
  quantity    Int
  item        Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId      String
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  warehouseId String
  user        User         @relation(fields: [userId], references: [id])
  userId      String
  supplier    String?
  note        String?
  createdAt   DateTime     @default(now())

  @@index([itemId, createdAt])
  @@index([warehouseId, createdAt])
}
