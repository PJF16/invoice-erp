generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
}

enum Module {
  STOCK
  INVOICES
}

enum TaxTreatment {
  STANDARD
  REVERSE_CHARGE
  INTRA_EU_SUPPLY
  EXPORT
}

enum InvoiceStatus {
  DRAFT
  OPEN
  SENT
  PAID
  CANCELED
}

enum InvoiceType {
  INVOICE
  CREDIT_NOTE
}

enum RecurringInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ExportPeriod {
  PREVIOUS_MONTH
  PREVIOUS_QUARTER
  PREVIOUS_YEAR
  ALL_TIME
}

enum MovementType {
  IN
  OUT
  ADJUST
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  CARD
  DIRECT_DEBIT
  PAYPAL
  OTHER
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         Role       @default(MEMBER)
  modules      Module[]   @default([STOCK, INVOICES])
  createdAt    DateTime   @default(now())
  movements    Movement[]
  payments     Payment[]
}

model Warehouse {
  id           String        @id @default(cuid())
  name         String        @unique
  location     String?
  createdAt    DateTime      @default(now())
  stocks       Stock[]
  movements    Movement[]
  invoiceLines InvoiceLine[]
}

model Item {
  id           String        @id @default(cuid())
  name         String
  sku          String?       @unique
  barcode      String?       @unique
  description  String?
  createdAt    DateTime      @default(now())
  stocks       Stock[]
  movements    Movement[]
  invoiceLines InvoiceLine[]
}

model Stock {
  id          String    @id @default(cuid())
  item        Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId      String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  warehouseId String
  quantity    Int       @default(0)

  @@unique([itemId, warehouseId])
}

model CompanySettings {
  id              String @id @default("singleton")
  name            String @default("")
  street          String @default("")
  zip             String @default("")
  city            String @default("")
  country         String @default("Österreich")
  uid             String @default("")
  iban            String @default("")
  bic             String @default("")
  bankName        String @default("")
  email           String @default("")
  phone           String @default("")
  invoicePrefix   String @default("")
  paymentDays     Int    @default(14)
  emailSubject    String @default("Rechnung {nummer}")
  emailBody       String @default("Sehr geehrte Damen und Herren,\n\nanbei erhalten Sie die Rechnung {nummer}.\n\nMit freundlichen Grüßen")
  lastInvoiceYear Int    @default(0)
  lastInvoiceSeq  Int    @default(0)
  autoReminders   Boolean @default(false)
  reminderDays    Int     @default(7)
  maxReminders    Int     @default(3)
  reminderSubject String  @default("Zahlungserinnerung zu Rechnung {nummer}")
  reminderBody    String  @default("Sehr geehrte Damen und Herren,\n\ndürfen wir Sie freundlich daran erinnern, dass die Rechnung {nummer} vom {datum} über {betrag} seit {tage} Tagen überfällig ist?\n\nBitte überweisen Sie den offenen Betrag auf das angegebene Konto. Sollte sich Ihre Zahlung mit dieser Erinnerung überschnitten haben, betrachten Sie dieses Schreiben bitte als gegenstandslos.\n\nMit freundlichen Grüßen")
  skontoPercent   Int     @default(0)
  skontoDays      Int     @default(0)
}

model Customer {
  id                  String             @id @default(cuid())
  customerNumber      String?            @unique
  name                String
  contactPerson       String?
  email               String?
  street              String             @default("")
  zip                 String             @default("")
  city                String             @default("")
  country             String             @default("Österreich")
  uid                 String?
  defaultTaxTreatment TaxTreatment       @default(STANDARD)
  notes               String?
  createdAt           DateTime           @default(now())
  invoices            Invoice[]
  recurringInvoices   RecurringInvoice[]
}

model SoftwareItem {
  id             String                 @id @default(cuid())
  name           String
  description    String?
  unitPrice      Decimal                @db.Decimal(10, 2)
  unit           String                 @default("Monat")
  active         Boolean                @default(true)
  createdAt      DateTime               @default(now())
  invoiceLines   InvoiceLine[]
  recurringLines RecurringInvoiceLine[]
}

model Invoice {
  id                 String            @id @default(cuid())
  number             String?           @unique
  type               InvoiceType       @default(INVOICE)
  relatedInvoice     Invoice?          @relation("Storno", fields: [relatedInvoiceId], references: [id])
  relatedInvoiceId   String?
  stornoInvoices     Invoice[]         @relation("Storno")
  reminderCount      Int               @default(0)
  lastReminderAt     DateTime?
  status             InvoiceStatus     @default(DRAFT)
  customer           Customer          @relation(fields: [customerId], references: [id])
  customerId         String
  customerName       String            @default("")
  customerAddress    String            @default("")
  customerUid        String?
  issueDate          DateTime
  dueDate            DateTime
  servicePeriodStart DateTime?
  servicePeriodEnd   DateTime?
  taxTreatment       TaxTreatment      @default(STANDARD)
  notes              String?
  netTotal           Decimal           @default(0) @db.Decimal(12, 2)
  taxTotal           Decimal           @default(0) @db.Decimal(12, 2)
  grossTotal         Decimal           @default(0) @db.Decimal(12, 2)
  paidTotal          Decimal           @default(0) @db.Decimal(12, 2)
  skontoGranted      Decimal           @default(0) @db.Decimal(12, 2)
  skontoPercent      Int               @default(0)
  skontoDays         Int               @default(0)
  recurringInvoice   RecurringInvoice? @relation(fields: [recurringInvoiceId], references: [id])
  recurringInvoiceId String?
  sentAt             DateTime?
  paidAt             DateTime?
  createdAt          DateTime          @default(now())
  lines              InvoiceLine[]
  payments           Payment[]

  @@index([status, issueDate])
}

model Payment {
  id        String        @id @default(cuid())
  invoice   Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String
  amount    Decimal       @db.Decimal(12, 2)
  date      DateTime
  method    PaymentMethod @default(BANK_TRANSFER)
  reference String?
  note      String?
  user      User          @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime      @default(now())

  @@index([invoiceId])
}

model InvoiceLine {
  id             String        @id @default(cuid())
  invoice        Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId      String
  position       Int
  description    String
  quantity       Decimal       @db.Decimal(10, 2)
  unit           String        @default("Stk")
  unitPrice      Decimal       @db.Decimal(10, 2)
  taxRate        Int           @default(20)
  lineNet        Decimal       @db.Decimal(12, 2)
  softwareItem   SoftwareItem? @relation(fields: [softwareItemId], references: [id], onDelete: SetNull)
  softwareItemId String?
  item           Item?         @relation(fields: [itemId], references: [id], onDelete: SetNull)
  itemId         String?
  warehouse      Warehouse?    @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  warehouseId    String?
}

model RecurringInvoice {
  id           String                 @id @default(cuid())
  name         String
  customer     Customer               @relation(fields: [customerId], references: [id])
  customerId   String
  interval     RecurringInterval      @default(MONTHLY)
  nextRun      DateTime
  active       Boolean                @default(true)
  autoSend     Boolean                @default(true)
  taxTreatment TaxTreatment           @default(STANDARD)
  notes        String?
  createdAt    DateTime               @default(now())
  lines        RecurringInvoiceLine[]
  invoices     Invoice[]
}

model RecurringInvoiceLine {
  id                 String           @id @default(cuid())
  recurringInvoice   RecurringInvoice @relation(fields: [recurringInvoiceId], references: [id], onDelete: Cascade)
  recurringInvoiceId String
  position           Int
  // Wenn softwareItemId gesetzt: Bezeichnung + Preis werden bei der Erzeugung
  // vom Softwareartikel gelesen (Preisänderungen wirken auf künftige Rechnungen).
  softwareItem       SoftwareItem?    @relation(fields: [softwareItemId], references: [id], onDelete: SetNull)
  softwareItemId     String?
  description        String?
  unitPrice          Decimal?         @db.Decimal(10, 2)
  quantity           Decimal          @db.Decimal(10, 2)
  unit               String           @default("Stk")
  taxRate            Int              @default(20)
}

model ExportSchedule {
  id             String            @id @default(cuid())
  name           String
  active         Boolean           @default(true)
  interval       RecurringInterval @default(MONTHLY)
  nextRun        DateTime
  period         ExportPeriod      @default(PREVIOUS_MONTH)
  types          InvoiceType[]     @default([INVOICE])
  recipientEmail String
  emailSubject   String            @default("Belegexport {zeitraum}")
  emailBody      String            @default("Sehr geehrte Damen und Herren,\n\nanbei der Belegexport für {zeitraum}.\n\nMit freundlichen Grüßen")
  lastRunAt      DateTime?
  createdAt      DateTime          @default(now())
}

model Movement {
  id          String       @id @default(cuid())
  type        MovementType
  quantity    Int
  item        Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId      String
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  warehouseId String
  user        User         @relation(fields: [userId], references: [id])
  userId      String
  supplier    String?
  note        String?
  createdAt   DateTime     @default(now())

  @@index([itemId, createdAt])
  @@index([warehouseId, createdAt])
}
