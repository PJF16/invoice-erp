generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
}

enum MovementType {
  IN
  OUT
  ADJUST
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         Role       @default(MEMBER)
  createdAt    DateTime   @default(now())
  movements    Movement[]
}

model Warehouse {
  id        String     @id @default(cuid())
  name      String     @unique
  location  String?
  createdAt DateTime   @default(now())
  stocks    Stock[]
  movements Movement[]
}

model Item {
  id          String     @id @default(cuid())
  name        String
  sku         String?    @unique
  barcode     String?    @unique
  description String?
  createdAt   DateTime   @default(now())
  stocks      Stock[]
  movements   Movement[]
}

model Stock {
  id          String    @id @default(cuid())
  item        Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId      String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  warehouseId String
  quantity    Int       @default(0)

  @@unique([itemId, warehouseId])
}

model Movement {
  id          String       @id @default(cuid())
  type        MovementType
  quantity    Int
  item        Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId      String
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  warehouseId String
  user        User         @relation(fields: [userId], references: [id])
  userId      String
  note        String?
  createdAt   DateTime     @default(now())

  @@index([itemId, createdAt])
  @@index([warehouseId, createdAt])
}
