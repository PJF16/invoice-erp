# Datenbank (Entwicklung: docker compose up -d db, Port 5433 auf dem Host)
DATABASE_URL="postgresql://erp:erp_dev_password@localhost:5433/invoice_erp"

# Auth.js Secret — generieren mit: openssl rand -base64 32
AUTH_SECRET=""

# Öffentliche URL der App (z.B. hinter Cloudflare Tunnel) — nötig, damit
# Auth.js-Redirects auf die richtige Domain zeigen statt auf 0.0.0.0:3000
AUTH_URL="https://erp.philipp.technology"

# Dem eingehenden Host-Header vertrauen (selbst gehostet / hinter Reverse-Proxy).
# Ohne "true" wirft Auth.js im Production-Build UntrustedHost. Auf "false" setzen,
# um es abzuschalten. Standard, wenn nicht gesetzt: vertrauen.
AUTH_TRUST_HOST=true

# Postgres-Container (docker-compose.yml)
POSTGRES_USER=erp
POSTGRES_PASSWORD=erp_dev_password
POSTGRES_DB=invoice_erp
POSTGRES_PORT=5433

# SMTP für den Rechnungsversand (z.B. Google Workspace, Microsoft 365, World4You)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Firma GmbH <rechnung@firma.at>"

# Optionaler separater Schlüssel für SMB-Passwörter in den Backup-Einstellungen.
# Wenn leer, wird AUTH_SECRET verwendet. Nach dem Speichern nicht mehr ändern,
# sonst muss das SMB-Passwort erneut eingegeben werden.
BACKUP_ENCRYPTION_KEY=""

# Optional: Zugangsdaten für den Seed-Admin (prisma db seed)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=admin1234
