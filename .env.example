# Datenbank (Entwicklung: docker compose up -d db, Port 5433 auf dem Host)
DATABASE_URL="postgresql://erp:erp_dev_password@localhost:5433/invoice_erp"

# Auth.js Secret — generieren mit: openssl rand -base64 32
AUTH_SECRET=""

# Postgres-Container (docker-compose.yml)
POSTGRES_USER=erp
POSTGRES_PASSWORD=erp_dev_password
POSTGRES_DB=invoice_erp
POSTGRES_PORT=5433

# Optional: Zugangsdaten für den Seed-Admin (prisma db seed)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=admin1234
